<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.aluno.task.ui.SplashFragment"
        android:label="SplashFragment">
        <action
            android:id="@+id/action_splashFragment_to_autentication"
            app:destination="@id/autentication"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <navigation
        android:id="@+id/autentication"
        app:startDestination="@id/loginFragment">

        <fragment
            android:id="@+id/loginFragment"
            android:name="com.aluno.task.ui.auth.LoginFragment"
            android:label="LoginFragment">
            <action
                android:id="@+id/action_loginFragment_to_registerFragment"
                app:destination="@id/registerFragment" />
            <action
                android:id="@+id/action_loginFragment_to_recoverAccountFragment"
                app:destination="@id/recoverAccountFragment" />
            <action
                android:id="@+id/action_loginFragment_to_homeFragment"
                app:destination="@id/homeFragment"
                app:popUpTo="@id/autentication"
                app:popUpToInclusive="true" />
        </fragment>

        <fragment
            android:id="@+id/registerFragment"
            android:name="com.aluno.task.ui.auth.RegisterFragment"
            android:label="RegisterFragment" />

        <fragment
            android:id="@+id/recoverAccountFragment"
            android:name="com.aluno.task.ui.auth.RecoverAccountFragment"
            android:label="RecoverAccountFragment" />

    </navigation>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.aluno.task.ui.HomeFragment"
        android:label="HomeFragment">
        <action
            android:id="@+id/action_homeFragment_to_formTaskFragment"
            app:destination="@id/formTaskFragment" />
    </fragment>

    <fragment
        android:id="@+id/formTaskFragment"
        android:name="com.aluno.task.ui.FormTaskFragment"
        android:label="FormTaskFragment" />

</navigation>
